		{"id":"9ad598807c65fe6b","type":"text","text":"Context Positional Frame #\nPRESENCE\n(00/00) = (∞/∞) = CPF#\n\n\n","x":-9008,"y":4100,"width":240,"height":100},
		{"id":"3fa533c087265894","type":"text","text":"Context Positional Frame #'\nEROS\n(4.0/1-4.4/5) = CPF#'\n","x":-9008,"y":4306,"width":240,"height":100},
