  "sharedBridgeAdapter": {
    "dependencySymbol": "KernelBridgeAPI",
    "requiredCapabilities": [
      "readCurrentProfile",
      "readPointerAnchor",
      "readReadiness",
      "subscribeObservability",
      "invokeGatewayRpc",
      "depositKernelObservation",
      "requestReviewEvidence"
    ],
    "requiredSubscriptions": [
      "onMathemeHarmonicProfile",
      "onConnectionStatusChange",
      "onObservabilityEvent"
    ],
    "forbiddenDirectImports": [
      "Body/S/S0",
      "Body/S/S2",
      "Body/S/S3",
      "Body/S/S5",
      "@clockworklabs/spacetimedb-sdk",
      "neo4j-driver",
      "redis",
      "portal-core",
      "epii-review-core",
      "epii-agent-core"
    ],
    "rule": "Individual extensions consume S0/S2/S3/S5 only through the shared bridge adapter or approved shared runtime package."
  },
  "readinessTaxonomy": [
    {
      "id": "bridge_unavailable",
      "severity": "blocked",
      "ownerTrack": "01",
      "meaning": "The shared bridge instance is absent, disconnected, or unreadable; extensions render no derived state."
    },
    {
      "id": "profile_missing_field",
      "severity": "blocked",
      "ownerTrack": "01",
      "meaning": "The current MathemeHarmonicProfile lacks a field the extension needs and must name the missing field explicitly."
    },
    {
      "id": "s2_graph_blocked",
      "severity": "blocked",
      "ownerTrack": "02",
      "meaning": "Coordinate-native graph law, provenance, or graph-service readiness is missing for the requested surface."
    },
    {
      "id": "s3_subscription_blocked",
      "severity": "blocked",
      "ownerTrack": "03",
      "meaning": "The shared stream/session/DAY-NOW path cannot provide ordered live state to the extension."
    },
    {
      "id": "s5_review_blocked",
      "severity": "blocked",
      "ownerTrack": "04",
      "meaning": "Review/evidence/governance state is not available for deep action or deposit surfaces."
    },
    {
      "id": "authority_payload_missing",
      "severity": "degraded",
      "ownerTrack": "02",
      "meaning": "The authoritative graph/profile/review payload for this display is not available, so the extension must show exactly which owner is missing instead of inferring defaults."
    },
    {
      "id": "privacy_blocked",
      "severity": "blocked",
      "ownerTrack": "03/04",
      "meaning": "Protected-local or consent-gated data cannot cross into the current surface."
    },
    {
      "id": "degraded_but_readable",
      "severity": "degraded",
      "ownerTrack": "01/02/03/04",
      "meaning": "A read-only or lower-fidelity view is safe to show, but write/deposit/deep interaction remains blocked."
    },
    {
      "id": "ready_public_current",
      "severity": "ready",
      "ownerTrack": "01/02/03/04",
      "meaning": "The surface has all current public-safe data and capabilities needed for its first slice."
    }
  ],
