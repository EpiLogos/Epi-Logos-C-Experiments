{
  "name": "@pratibimba/theia-app",
  "version": "0.1.0",
  "private": true,
  "description": "Theia browser application that hosts the Pratibimba System IDE surface.",
  "license": "MIT",
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "Pratibimba System",
        "preferences": {
          "files.enableTrash": false
        }
      }
    }
  },
  "dependencies": {
    "@theia/core": "1.56.0",
    "@theia/filesystem": "1.56.0",
    "@theia/messages": "1.56.0",
    "@theia/userstorage": "1.56.0",
    "@theia/variable-resolver": "1.56.0",
    "@theia/workspace": "1.56.0",
    "@pratibimba/kernel-bridge-readiness": "workspace:*"
  },
  "devDependencies": {
    "@theia/cli": "1.56.0",
    "typescript": "~5.4.5"
  },
  "scripts": {
    "build": "theia build --mode development",
    "build:prod": "theia build --mode production",
    "clean": "theia clean && rimraf lib src-gen .browser_modules",
    "watch": "theia build --watch --mode development",
    "start": "theia start --plugins=local-dir:plugins --hostname=127.0.0.1 --port=3000",
    "start:debug": "theia start --plugins=local-dir:plugins --inspect --hostname=127.0.0.1 --port=3000"
  }
}
