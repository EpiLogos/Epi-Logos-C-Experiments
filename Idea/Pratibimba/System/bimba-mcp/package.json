{
  "name": "bimba-mcp",
  "version": "0.1.0",
  "description": "MCP server for Bimba coordinate system and Neo4j knowledge graph access",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bimba-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:inspector": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js --test tests/inspector-tests.json",
    "test:inspector:ui": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bimba",
    "neo4j",
    "claude"
  ],
  "author": "epi-logos",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "langchain": "^1.2.15",
    "neo4j-driver": "^5.28.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/ui": "^4.0.18",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
