{
  "name": "@pratibimba/system",
  "version": "0.1.0",
  "private": true,
  "description": "Pratibimba System — Theia-based IDE surface for the Epi-Logos M5-3 layer. Hosts the six individual M-extensions, two integrated plugins (1-2-3 and 4/5/0), and the foundational kernel-bridge.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rm -rf theia-app/lib theia-app/src-gen theia-app/gen-webpack.* node_modules",
    "watch": "pnpm -r --parallel watch",
    "start": "pnpm --dir theia-app start",
    "start:debug": "pnpm --dir theia-app start:debug",
    "test": "pnpm -r test && pnpm test:contracts",
    "test:contracts": "node --test extensions/test/shared-bridge-fan-out.test.mjs extensions/test/activation-and-persistence.test.mjs extensions/test/m0-anuttara-inspector.test.mjs extensions/test/m1-paramasiva-clock-instrument.test.mjs extensions/test/m2-parashakti-meaning-packet.test.mjs extensions/test/m3-mahamaya-codon-wheel.test.mjs extensions/test/track-08-contribution-contract.test.mjs extensions/test/track-08-integrated-layout-contract.test.mjs extensions/test/validate-extension-contract-preflight.test.mjs extensions/test/validate-composition-contract-preflight.test.mjs",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "~20.10.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.4.5"
  },
  "pnpm": {
    "overrides": {
      "@vscode/ripgrep": "1.15.9"
    },
    "onlyBuiltDependencies": [
      "@vscode/ripgrep",
      "@parcel/watcher",
      "msgpackr-extract"
    ],
    "patchedDependencies": {
      "@theia/application-manager@1.56.0": "patches/@theia__application-manager@1.56.0.patch"
    }
  },
  "packageManager": "pnpm@10.25.0"
}
