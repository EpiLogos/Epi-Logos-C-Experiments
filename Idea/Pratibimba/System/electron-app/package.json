{
  "name": "@pratibimba/electron-app",
  "version": "0.1.0",
  "private": true,
  "description": "Theia Electron application target for the Pratibimba System IDE. Reuses the same extensions as the browser-target theia-app. Track 05 T1-amendment / ADR-05-004 / ADR-05-005.",
  "license": "MIT",
  "main": "lib/backend/electron-main.js",
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Pratibimba System",
        "preferences": {
          "files.enableTrash": false
        }
      }
    }
  },
  "dependencies": {
    "@theia/core": "1.56.0",
    "@theia/electron": "1.56.0",
    "@theia/filesystem": "1.56.0",
    "@theia/messages": "1.56.0",
    "@theia/preferences": "1.56.0",
    "@theia/userstorage": "1.56.0",
    "@theia/variable-resolver": "1.56.0",
    "@theia/workspace": "1.56.0",
    "@pratibimba/kernel-bridge-readiness": "workspace:*",
    "@pratibimba/kernel-bridge": "workspace:*",
    "@pratibimba/m-extension-runtime": "workspace:*",
    "@pratibimba/pratibimba-layouts": "workspace:*",
    "@pratibimba/omnipanel-shell": "workspace:*",
    "@pratibimba/m0-anuttara": "workspace:*",
    "@pratibimba/m1-paramasiva": "workspace:*",
    "@pratibimba/m2-parashakti": "workspace:*",
    "@pratibimba/m3-mahamaya": "workspace:*",
    "@pratibimba/m4-nara": "workspace:*",
    "@pratibimba/m5-epii": "workspace:*",
    "@pratibimba/integrated-composition": "workspace:*",
    "@pratibimba/plugin-integrated-1-2-3": "workspace:*",
    "@pratibimba/plugin-integrated-4-5-0": "workspace:*"
  },
  "devDependencies": {
    "@theia/cli": "1.56.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "~5.4.5"
  },
  "scripts": {
    "build": "EPI_SKIP_FFMPEG_REPLACE=1 theia build --mode development",
    "build:prod": "EPI_SKIP_FFMPEG_REPLACE=1 theia build --mode production",
    "clean": "theia clean && rimraf lib src-gen dist",
    "watch": "EPI_SKIP_FFMPEG_REPLACE=1 theia build --watch --mode development",
    "start": "EPI_SKIP_FFMPEG_REPLACE=1 theia start",
    "dev": "pnpm run build && pnpm run start",
    "package:dir": "electron-builder --dir",
    "package": "electron-builder",
    "dist:dir": "pnpm run build:prod && pnpm run package:dir"
  }
}
