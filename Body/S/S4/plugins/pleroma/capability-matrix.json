  "hooks": {
    "manifest": "hooks.json",
    "role": "bounded-runtime-extension",
    "lifecycle_contract": {
      "pre_tool_call": {
        "coordinate_owner": "S4'",
        "role": "VAK and permission gate before action",
        "inputs": [
          "DAY/NOW",
          "session_key",
          "active_agent",
          "tool_name",
          "vak_evaluation",
          "permission_boundary"
        ],
        "must_emit": [
          "portal.vak_eval",
          "portal.lens_pressure"
        ]
      },
      "post_tool_call": {
        "coordinate_owner": "S4'",
        "role": "Psyche observation of context, kbase field, and current task after action",
        "inputs": [
          "tool_result",
          "session_key",
          "psyche_state_ref",
          "kbase_refs"
        ],
        "must_emit": [
          "portal.tool_call"
        ]
      },
      "transform_tool_result": {
        "coordinate_owner": "S4'/S3'",
        "role": "Coordinate-aware result wrapping over DAY/NOW/session-aware gateway events",
        "inputs": [
          "raw_result",
          "coordinate_context",
          "day_id",
          "now_path",
          "session_key"
        ],
        "must_emit": [
          "portal.review_deposit",
          "portal.kairos_shift"
        ]
      }
    }
  },
  "typed_delegation": {
    "delegate_lens": {
      "method": "s4'.pleroma.delegate_lens",
      "arguments": [
        "lens_id",
        "task",
        "day_id",
        "session_key"
      ],
      "return_policy": "summary_only_with_evidence_refs"
    },
    "delegate_square": {
      "method": "s4'.pleroma.delegate_square",
      "arguments": [
        "square_id",
        "task",
        "day_id",
        "session_key"
      ],
      "return_policy": "summary_only_with_evidence_refs"
    },
    "gate_observability": {
      "method": "s4'.pleroma.gate.evaluate",
      "returns": [
        "allowed",
        "agent",
        "tools",
        "skills",
        "vak",
        "reason"
      ]
    }
  },
  "provider_profile_contract": {
    "coordinate_owner": "S4",
    "trait_target": "PiProviderProfile",
    "attributes": [
      "fixed_temperature",
      "default_aux_model",
      "prepare_messages",
      "build_extra_body",
      "build_api_kwargs_extras",
      "fetch_models",
      "auth_type",
      "env_vars",
      "base_url"
    ],
    "residency": "Body/S/S4/pi-agent provider abstraction; S0 agent model commands remain mirrors"
  },
  "execution_backbone": {
    "name": "tilldone",
    "source": "vendors/pi-vs-claude-code/extensions/tilldone.ts",
    "body_path": "Body/S/S4/ta-onta/S4-2p-pleroma/S2/tilldone.ts",
    "scope": "anima_execution_runs",
    "enabled_for": [
      "anima"
    ],
    "gate": "requires an active TillDone task list before non-TillDone tool use",
    "disable_env": "EPI_TILLDONE_MODE=off",
    "force_env": "EPI_TILLDONE_MODE=on"
  },
