  "hooks": {
    "manifest": "hooks.json",
    "role": "bounded-runtime-extension",
    "lifecycle_contract": {
      "pre_tool_call": {
        "coordinate_owner": "S4'",
        "role": "VAK and permission gate before action",
        "inputs": [
          "DAY/NOW",
          "session_key",
          "active_agent",
          "tool_name",
          "vak_evaluation",
          "permission_boundary"
        ],
        "must_emit": [
          "portal.vak_eval",
          "portal.lens_pressure"
        ]
      },
      "post_tool_call": {
        "coordinate_owner": "S4'",
        "role": "Psyche observation of context, kbase field, and current task after action",
        "inputs": [
          "tool_result",
          "session_key",
          "psyche_state_ref",
          "kbase_refs"
        ],
        "must_emit": [
          "portal.tool_call"
        ]
      },
      "transform_tool_result": {
        "coordinate_owner": "S4'/S3'",
        "role": "Coordinate-aware result wrapping over DAY/NOW/session-aware gateway events",
        "inputs": [
          "raw_result",
          "coordinate_context",
          "day_id",
          "now_path",
          "session_key"
        ],
        "must_emit": [
          "portal.review_deposit",
          "portal.kairos_shift"
        ]
      }
    }
  },
  "typed_delegation": {
    "delegate_lens": {
