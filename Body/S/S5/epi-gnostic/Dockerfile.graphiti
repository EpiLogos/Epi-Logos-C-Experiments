FROM python:3.11-slim

WORKDIR /app

# Install build deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
COPY epi_gnostic/ ./epi_gnostic/

RUN pip install --no-cache-dir -e ".[graphiti]"

EXPOSE 37778

CMD ["python", "-m", "epi_gnostic.graphiti_service"]
