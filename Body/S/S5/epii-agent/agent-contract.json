{
  "agent_id": "epii",
  "coordinate": "S5/S5'",
  "agent_kind": "pi_agent",
  "relation_to_anima": "peer_pi_agent",
  "pi_runtime_agent_id": "epii",
  "pi_gateway_session_key": "agent:epii:main",
  "plugin_registry": "Body/S/S5/plugins/registry.jsonl",
  "resource_package": "epi-logos",
  "resource_package_target": "Body/S/S5/plugins/epi-logos",
  "resource_package_status": "vendor_promoted_canonical_body",
  "resource_package_vendor_source": "vendors/epi-logos",
  "agent_access_core": "Body/S/S5/epii-agent-core",
  "gateway_methods": [
    "s5'.epii.status",
    "s5'.epii.deposit",
    "s5'.review.submit",
    "s5'.review.inbox",
    "s5'.review.resolve",
    "s5'.review.history",
    "s5'.improve.status",
    "s5'.improve.propose",
    "s5'.improve.evaluate",
    "s5'.improve.promote",
    "s5'.improve.history"
  ],
  "spines": [
    "autoresearch",
    "review_inbox"
  ],
  "accepted_deposits_from_anima": [
    "review_item",
    "improvement_request",
    "validation_gate",
    "aletheia_crystallisation"
  ],
  "allowed_requests_to_anima": [
    "dispatch_request",
    "implementation_request",
    "runtime_action_request",
    "validation_support_request"
  ],
  "epii_authority": [
    "resolve_review_gate",
    "accept_or_reject_validation",
    "observe_and_improve_system",
    "steward_user_pratibimba_identity",
    "request_anima_dispatch"
  ],
  "forbidden_authority": [
    "bypass_anima_dispatch_boundaries",
    "mutate_raw_runtime_state_without_review_record",
    "treat_anima_constitutional_agents_as_epii_subagents"
  ],
  "inbox_contract": {
    "purpose": "Make Anima and Aletheia work reviewable by the PI agent position to which their outputs make sense.",
    "inbox_path_template": "Idea/Empty/Present/{day-date}/",
    "path_rule": "The Epii inbox is day-scoped. Deposits live in the active DAY container and carry NOW/session lineage in frontmatter or receipt metadata rather than being buried inside one NOW session folder.",
    "access_pattern": {
      "summary_first": "Epii tooling surfaces active day inbox counts first.",
      "full_items": "Full deposit files and review records are opened on demand from the day container.",
      "anima_access": "Anima and Aletheia may deposit and request validation, but cannot resolve Epii review gates."
    },
    "required_fields": [
      "source_agent",
      "source_coordinate",
      "request_type",
      "artifact_ref",
      "day_id",
      "now_path",
      "session_key",
      "validation_required",
      "created_at"
    ]
  },
  "autoresearch_contract": {
    "purpose": "Turn the prior architecture back upon itself to observe, research, and improve the system from inside its own philosophy.",
    "inputs": [
      "inbox_item",
      "system_observation",
      "code_state",
      "spec_trace"
    ],
    "outputs": [
      "research_note",
      "improvement_hypothesis",
      "implementation_request",
      "alignment_review"
    ]
  }
}
